generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  password               String
  name                   String?
  role                   UserRole                 @default(USER)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  ProductTransfer        ProductTransfer[]
  RawMaterialTransfer    RawMaterialTransfer[]
  UserInventory          UserInventory[]
  RawMaterialConsumption RawMaterialConsumption[]
}

model UserCustomer {
  id             Int      @id @default(autoincrement())
  name           String
  email          String?
  phone          String   @unique
  billingAddress String?
  gst            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  pan            String?

  @@index([name])
  @@index([email])
  @@index([phone])
  @@index([gst])
  @@index([createdAt])
}

model Customer {
  id          Int            @id @default(autoincrement())
  name        String
  address     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  email       String?
  number      String         @unique
  invoices    Invoice[]
  shipping    ShippingInfo[]
  creditNotes CreditNote[]
  payments    Payment[]
}

model Vendor {
  id             Int                @id @default(autoincrement())
  name           String
  phone          String?
  email          String?
  companyName    String?
  gstin          String?            @unique
  address        String?
  openingBalance Float?             @default(0)
  creditLimit    Float?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  bills          Bill[]
  purchaseBills  PurchaseBill[]
  creditNotes    VendorCreditNote[]
  payments       VendorPayment[]

  @@index([name])
  @@index([gstin])
}

model VendorCreditNote {
  id               String                 @id @default(cuid())
  creditNoteNumber String                 @unique
  vendorId         Int
  billNumber       String?
  issueDate        DateTime               @default(now())
  reason           String
  amount           Float
  taxAmount        Float                  @default(0)
  totalAmount      Float
  notes            String?
  status           VendorCreditNoteStatus @default(DRAFT)
  appliedToBill    Boolean                @default(false)
  appliedDate      DateTime?
  appliedBillId    Int?                   @unique
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  productName      String?
  appliedBill      Bill?                  @relation(fields: [appliedBillId], references: [id])
  vendor           Vendor                 @relation(fields: [vendorId], references: [id])

  @@map("vendor_credit_notes")
}

model PurchaseBill {
  id                 String             @id @default(cuid())
  billNumber         String             @unique
  orderNumber        String?
  vendorId           Int
  billDate           DateTime
  dueDate            DateTime?
  paymentTerms       PaymentTermType    @default(DUE_ON_RECEIPT)
  customPaymentTerms String?
  subject            String?
  subtotal           Float              @default(0)
  discountType       String?
  discountValue      Float?             @default(0)
  discountAmount     Float?             @default(0)
  taxAmount          Float?             @default(0)
  adjustment         Float?             @default(0)
  total              Float              @default(0)
  amountPaid         Float              @default(0)
  balanceDue         Float              @default(0)
  status             BillStatus         @default(DRAFT)
  notes              String?
  attachments        String[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  items              PurchaseBillItem[]
  vendor             Vendor             @relation(fields: [vendorId], references: [id])

  @@map("purchase_bills")
}

model PurchaseBillItem {
  id          String       @id @default(cuid())
  billId      String
  productId   Int?
  itemName    String
  description String?
  account     String?
  quantity    Float        @default(1)
  rate        Float        @default(0)
  amount      Float        @default(0)
  taxRate     Float?       @default(0)
  taxAmount   Float?       @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  bill        PurchaseBill @relation(fields: [billId], references: [id], onDelete: Cascade)
  product     Product?     @relation(fields: [productId], references: [id])

  @@map("purchase_bill_items")
}

model PurchaseBillCounter {
  id            String   @id @default(cuid())
  financialYear String   @unique
  lastNumber    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("purchase_bill_counters")
}

model VendorPayment {
  id              String              @id @default(cuid())
  vendorId        Int
  amount          Float
  paymentMethod   VendorPaymentMethod
  transactionId   String?
  referenceNumber String              @unique
  paymentDate     DateTime            @default(now())
  billNumbers     String[]
  status          VendorPaymentStatus @default(DUE)
  dueDate         DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  productName     String?
  vendor          Vendor              @relation(fields: [vendorId], references: [id])

  @@map("vendor_payments")
}

model Bill {
  id                Int               @id @default(autoincrement())
  billNumber        String            @unique
  vendorId          Int
  billDate          DateTime
  dueDate           DateTime
  subtotal          Float
  taxAmount         Float
  totalAmount       Float
  amountPaid        Float             @default(0)
  balanceDue        Float
  paymentTerms      String?
  status            BillStatus        @default(DRAFT)
  notes             String?
  itemsDescription  String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  vendor            Vendor            @relation(fields: [vendorId], references: [id])
  appliedCreditNote VendorCreditNote?

  @@map("bills")
}

model VendorCreditNoteCounter {
  id            String @id @default(cuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("vendor_credit_note_counters")
}

model VendorPaymentCounter {
  id            String @id @default(cuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("vendor_payment_counters")
}

model BillCounter {
  id            String @id @default(cuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("bill_counters")
}

model ShippingInfo {
  id         Int       @id @default(autoincrement())
  name       String
  address    String
  customerId Int?
  invoice    Invoice[]
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("categories")
}

model Product {
  name                   String
  price                  Float
  size                   String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  id                     Int                      @id @default(autoincrement())
  quantity               Int                      @default(0)
  costPrice              Float?
  category               String?
  items                  InvoiceItem[]
  ProductStructure       ProductStructure[]
  ProductTransfer        ProductTransfer[]
  purchaseBillItems      PurchaseBillItem[]
  RawMaterialConsumption RawMaterialConsumption[]
}

model Invoice {
  id            Int           @id @default(autoincrement())
  invoiceNumber String        @unique
  invoiceDate   DateTime
  dueDate       DateTime
  customerId    Int
  shippingId    Int?
  subtotal      Float
  cgst          Float
  sgst          Float
  total         Float
  advancePaid   Float         @default(0)
  balanceDue    Float
  totalInWords  String
  deliveryDate  DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  status        String        @default("DRAFT")
  companyType   String?       @default("RUDRA")
  extraCharges  Float         @default(0)
  description   String        @default("")
  discountType String  @default("amount")
  discount      Float         @default(0)
  customer      Customer      @relation(fields: [customerId], references: [id])
  shipping      ShippingInfo? @relation(fields: [shippingId], references: [id])
  items         InvoiceItem[]
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int
  productId   Int
  name        String
  quantity    Int
  price       Float
  total       Float
  notes       String?
  description String?
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RawMaterial {
  id                     Int                      @id @default(autoincrement())
  name                   String
  quantity               Float                    @default(0)
  unit                   String?                  @default("pcs")
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  productStructures      ProductStructure[]
  transfers              RawMaterialTransfer[]
  UserInventory          UserInventory[]
  RawMaterialConsumption RawMaterialConsumption[]
}

model ProductStructure {
  id               Int         @id @default(autoincrement())
  productId        Int
  rawMaterialId    Int
  quantityRequired Float
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  materialName     String?
  productName      String?
  unit             String?
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterial      RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)

  @@unique([productId, rawMaterialId])
}

model RawMaterialTransfer {
  id               Int            @id @default(autoincrement())
  userId           String
  rawMaterialId    Int
  quantityIssued   Float
  status           TransferStatus @default(SENT)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  quantityApproved Float?         @default(0)
  quantityRejected Float?         @default(0)
  rejectionReason  String?
  rejectionImages  String[]
  rawMaterial      RawMaterial    @relation(fields: [rawMaterialId], references: [id])
  user             User           @relation(fields: [userId], references: [id])
}

model ProductTransfer {
  id           Int                   @id @default(autoincrement())
  userId       String
  productId    Int
  quantitySent Int
  status       ProductTransferStatus @default(SENT)
  notes        String?
  receivedBy   String?
  receivedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  product      Product               @relation(fields: [productId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])
}

model UserInventory {
  id            Int         @id @default(autoincrement())
  userId        String
  rawMaterialId Int
  quantity      Float       @default(0)
  unit          String      @default("pcs")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, rawMaterialId])
}

model RawMaterialConsumption {
  id                      Int         @id @default(autoincrement())
  userId                  String
  productId               Int
  rawMaterialId           Int
  quantityUsed            Float
  unit                    String
  productTransferQuantity Int
  notes                   String?
  createdAt               DateTime    @default(now())
  product                 Product     @relation(fields: [productId], references: [id])
  rawMaterial             RawMaterial @relation(fields: [rawMaterialId], references: [id])
  user                    User        @relation(fields: [userId], references: [id])

  @@map("raw_material_consumption")
}

model Payment {
  id            String        @id @default(cuid())
  amount        Float
  paymentMethod PaymentMethod
  transactionId String?
  receiptNumber String        @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  balanceDue    Float?
  dueDate       DateTime?
  status        PaymentStatus @default(DUE)
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id])

  @@map("payments")
}

model ReceiptCounter {
  id            String @id @default(cuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("receipt_counters")
}

model CreditNote {
  id               String           @id @default(cuid())
  creditNoteNumber String           @unique
  invoiceNumber    String?
  customerId       Int
  issueDate        DateTime         @default(now())
  reason           String
  amount           Float
  taxAmount        Float            @default(0)
  totalAmount      Float
  notes            String?
  status           CreditNoteStatus @default(DRAFT)
  appliedToInvoice Boolean          @default(false)
  appliedDate      DateTime?
  appliedInvoiceId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  customer         Customer         @relation(fields: [customerId], references: [id])

  @@map("credit_notes")
}

model CreditNoteCounter {
  id            String @id @default(cuid())
  financialYear String @unique
  lastNumber    Int    @default(0)

  @@map("credit_note_counters")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  USER
}

enum VendorCreditNoteStatus {
  DRAFT
  ISSUED
  APPLIED
  CANCELLED
}

enum BillStatus {
  DRAFT
  OPEN
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum PaymentTermType {
  DUE_ON_RECEIPT
  NET_15
  NET_30
  NET_45
  NET_60
  CUSTOM
}

enum VendorPaymentStatus {
  DUE
  PAID
  OVERDUE
  PARTIAL
}

enum VendorPaymentMethod {
  UPI
  CASH
  BANK_TRANSFER
  CARD
  CHEQUE
  ONLINE
}

enum TransferStatus {
  SENT
  USED
  RETURNED
  CANCELLED
  REPAIRING
  FINISHED
  UNUSED
}

enum ProductTransferStatus {
  SENT
  RECEIVED
  REJECTED
  CANCELLED
}

enum PaymentStatus {
  COMPLETED
  DUE
  OVERDUE
}

enum PaymentMethod {
  UPI
  CASH
  BANK_TRANSFER
  CARD
}

enum CreditNoteStatus {
  DRAFT
  ISSUED
  CANCELLED
  APPLIED
}
